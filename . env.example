# Circle API Key (get from Circle Developer Console)
CIRCLE_API_KEY=your_api_key_here

# Wallet private key (funded from faucet.circle.com)
PRIVATE_KEY=0xyour_private_key_here

# Arc Testnet RPC (optional, has default)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Test recipient for payment examples
TEST_RECIPIENT=0xrecipient_address_here

# Payment amount (in USDC)
PAYMENT_AMOUNT=1
